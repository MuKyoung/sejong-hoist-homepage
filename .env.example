# ── Supabase (CMS) ────────────────────────────────────────────
# Copy to `.env.local` and fill in from Supabase → Project Settings → API.
# Never commit real values. .env.local is gitignored.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Bypasses RLS — keep secret, never expose to the browser.
# Optional for Phase 1 (only needed for inviting users from the app).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
